# エディタ用 Azure AI Foundry 基盤 — デプロイ環境変数サンプル
#
# 使い方:
#   cp .env.sample .env   # .env は .gitignore 済み（コミットしない）
#   .env の値を実値に置き換える
#   ./scripts/deploy.sh   # deploy.sh が .env を読み込んでデプロイ
#
# ここには「環境ごとに変わる値・秘密情報」を置く。
# モデル一覧（catalog）は既定で infra/main.bicepparam の defaultModelDeployments を使う。
# 下の MODEL_DEPLOYMENTS を設定した場合のみ、それ（JSON）で上書きする。

# ---- Azure デプロイ先 --------------------------------------------------------
# 空なら現在の az account を使用。指定すると deploy.sh が az account set する
AZURE_SUBSCRIPTION_ID=
# データ所在の前提。国内リージョン
LOCATION=japaneast
# 既存 OPSNOTE 用リソースとは別 RG
RESOURCE_GROUP=rg-editor-openai
# リソース名の基礎文字列
BASE_NAME=editor-aoai

# ---- R2: IP allowlist（必須）------------------------------------------------
# カンマ区切りのグローバル IP。/32 は省略可（自動付与）。
# 台帳（申請者・追加日）はこの .env のコメント、または別途台帳に残すこと。
# 例: オフィス回線,VPN egress
ALLOWED_IPS=203.0.113.10/32,203.0.113.20/32

# ---- 通知（必須）------------------------------------------------------------
# Teams Workflows (Power Automate「Webhook 要求を受信したとき」) の URL。秘密。
TEAMS_WEBHOOK_URL=
# 運用者メール（Budget ソフト通知・Function 失敗アラート宛先）。カンマ区切り
OPS_EMAILS=ops@example.com

# ---- R3: コスト上限（必須）---------------------------------------------------
# 月次予算（課金通貨）。初期値の目安: 想定利用の 2〜3 倍
MONTHLY_BUDGET_AMOUNT=100000
# 当月 1 日（YYYY-MM-01）
BUDGET_START_DATE=2026-07-01

# ---- 任意 -------------------------------------------------------------------
# 利用者 Entra グループ objectId（Key Vault Secrets User を付与）。未定なら空
USERS_GROUP_OBJECT_ID=
# 初回デプロイのみ true（key1 を Key Vault へ初期投入）。運用開始後は必ず false。
# deploy.sh --first-run でも true にできる
SEED_INITIAL_KEY=false

# ---- 任意: モデル catalog を .env で上書き ------------------------------------
# 未設定なら main.bicepparam の defaultModelDeployments（フェーズ1: OpenAI 2モデル）を使う。
# 設定する場合は「1行の JSON 配列」で記述する（改行不可）。
# 各要素: name / modelName / modelVersion / format / sku / capacity
#   sku: 'Standard'=国内完結 / 'DataZoneStandard'=APAC(越境)
#   format: OpenAI / DeepSeek / xAI / 'Mistral AI' / Microsoft
# フェーズ2で DeepSeek を足す例（modelName/version は list-models で確認してから）:
# MODEL_DEPLOYMENTS=[{"name":"gpt41mini-jp","modelName":"gpt-4.1-mini","modelVersion":"2025-04-14","format":"OpenAI","sku":"Standard","capacity":50},{"name":"gpt5codex-apac","modelName":"gpt-5.3-codex","modelVersion":"2026-02-24","format":"OpenAI","sku":"DataZoneStandard","capacity":20},{"name":"deepseek-apac","modelName":"DeepSeek-V4-Pro","modelVersion":"","format":"DeepSeek","sku":"DataZoneStandard","capacity":20}]
#MODEL_DEPLOYMENTS=
